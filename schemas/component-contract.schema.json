{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contract-driven.design/schemas/component-contract.schema.json",
  "title": "Contract-Driven Component Contract",
  "type": "object",
  "required": [
    "spec_version",
    "component",
    "version",
    "kind",
    "description",
    "instructions",
    "input",
    "output",
    "errors",
    "policies",
    "sideEffects",
    "guarantees",
    "annotations"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_version": { "type": "string", "const": "1.0.0" },
    "component": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["stateless", "stateful", "async", "streaming"] },
    "description": { "type": "string", "minLength": 1 },
    "instructions": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/objectSchema" }
    },
    "output": { "$ref": "#/$defs/objectSchema" },
    "state": {
      "type": "object",
      "required": ["type", "properties"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "object" },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["type", "default"],
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string" },
              "default": {}
            }
          }
        }
      }
    },
    "async": {
      "type": "object",
      "required": ["completion", "delivery", "ordering", "timeoutMs", "cancellation"],
      "additionalProperties": false,
      "properties": {
        "completion": { "type": "string", "enum": ["required", "optional"] },
        "delivery": { "type": "string", "enum": ["at-most-once", "at-least-once", "exactly-once"] },
        "ordering": { "type": "string", "enum": ["none", "per-key", "global"] },
        "maxInFlight": { "type": "integer", "minimum": 1 },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "cancellation": {
          "type": "object",
          "required": ["supported", "semantics"],
          "additionalProperties": false,
          "properties": {
            "supported": { "type": "boolean" },
            "semantics": { "type": "string", "enum": ["best-effort", "guaranteed"] }
          }
        }
      }
    },
    "stream": {
      "type": "object",
      "required": ["messageSchema", "terminalEvents", "ordering", "backpressure"],
      "additionalProperties": false,
      "properties": {
        "messageSchema": { "$ref": "#/$defs/objectSchema" },
        "terminalEvents": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["completed", "failed", "cancelled"] }
        },
        "ordering": { "type": "string", "enum": ["none", "per-key", "global"] },
        "backpressure": { "type": "string", "enum": ["drop", "buffer", "block", "error"] },
        "replay": { "type": "string", "enum": ["none", "from-offset", "from-timestamp"] },
        "cancellation": {
          "type": "object",
          "required": ["supported", "semantics"],
          "additionalProperties": false,
          "properties": {
            "supported": { "type": "boolean" },
            "semantics": { "type": "string", "enum": ["best-effort", "guaranteed"] }
          }
        }
      }
    },
    "errors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["retryable", "description"],
        "additionalProperties": false,
        "properties": {
          "retryable": { "type": "boolean" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "policies": {
      "type": "object",
      "required": ["idempotency", "timeoutMs"],
      "additionalProperties": false,
      "properties": {
        "idempotency": { "type": "string", "enum": ["required", "not-required"] },
        "timeoutMs": { "type": "integer", "minimum": 1 }
      }
    },
    "sideEffects": {
      "type": "object",
      "required": ["allowed", "forbidden"],
      "additionalProperties": false,
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" } },
        "forbidden": { "type": "array", "items": { "type": "string" } }
      }
    },
    "guarantees": {
      "type": "object",
      "required": ["verifiable", "aspirational"],
      "additionalProperties": false,
      "properties": {
        "verifiable": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["operation", "assertion", "test"],
            "additionalProperties": false,
            "properties": {
              "operation": { "type": "string", "minLength": 1 },
              "assertion": { "type": "string", "minLength": 1 },
              "test": { "type": "string", "minLength": 1 }
            }
          }
        },
        "aspirational": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["statement", "enforcement"],
            "additionalProperties": false,
            "properties": {
              "statement": { "type": "string", "minLength": 1 },
              "enforcement": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "annotations": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["readOnly", "destructive", "idempotent", "openWorld"],
        "additionalProperties": false,
        "properties": {
          "readOnly": { "type": "boolean" },
          "destructive": { "type": "boolean" },
          "idempotent": { "type": "boolean" },
          "openWorld": { "type": "boolean" }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["status", "since"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["draft", "stable", "deprecated"] },
        "since": { "type": "string", "minLength": 1 },
        "replaces": { "type": "string" }
      }
    },
    "requires": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component", "version", "guarantees_assumed"],
        "additionalProperties": false,
        "properties": {
          "component": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "guarantees_assumed": { "type": "array", "items": { "type": "string" } },
          "failurePolicy": {
            "type": "object",
            "required": ["mode", "timeoutMs", "mapErrors"],
            "additionalProperties": false,
            "properties": {
              "mode": { "type": "string", "enum": ["fail-closed", "fail-open", "degraded"] },
              "timeoutMs": { "type": "integer", "minimum": 1 },
              "mapErrors": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "projection": {
      "type": "object",
      "required": ["protocol", "lossless", "preserved_fields"],
      "additionalProperties": false,
      "properties": {
        "protocol": { "type": "string" },
        "lossless": { "type": "boolean" },
        "preserved_fields": { "type": "array", "items": { "type": "string" } },
        "dropped_fields": { "type": "array", "items": { "type": "string" } },
        "fallback_encoding": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "stateful" } }, "required": ["kind"] },
      "then": { "required": ["state"] }
    },
    {
      "if": { "properties": { "kind": { "const": "async" } }, "required": ["kind"] },
      "then": { "required": ["async"] }
    },
    {
      "if": { "properties": { "kind": { "const": "streaming" } }, "required": ["kind"] },
      "then": { "required": ["stream"] }
    }
  ],
  "$defs": {
    "primitiveSchema": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "enum": ["integer", "string", "boolean", "object", "array"] },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "minLength": { "type": "integer", "minimum": 0 },
        "maxLength": { "type": "integer", "minimum": 0 },
        "default": {},
        "description": { "type": "string" },
        "properties": { "type": "object", "additionalProperties": true },
        "required": { "type": "array", "items": { "type": "string" } },
        "additionalProperties": { "type": "boolean" }
      }
    },
    "objectSchema": {
      "type": "object",
      "required": ["type", "properties", "required"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "object" },
        "additionalProperties": { "type": "boolean" },
        "properties": { "type": "object", "additionalProperties": { "$ref": "#/$defs/primitiveSchema" } },
        "required": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
